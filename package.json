{
  "name": "@civitas-cerebrum/test-coverage",
  "version": "0.0.1",
  "description": "Checks if public methods of TypeScript classes are called in test files via AST analysis.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "test-coverage": "dist/cli.js"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc && node scripts/fix-shebang.js",
    "postbuild": "chmod +x dist/cli.js",
    "test": "jest",
    "prepublishOnly": "npm run clean && npm run build && npm test"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "glob": "^10.4.5",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/civitas-cerebrum/test-coverage.git"
  },
  "author": "Umut Ay Bora",
  "license": "MIT",
  "keywords": [
    "typescript",
    "test-coverage",
    "ast",
    "static-analysis",
    "api-integrity",
    "automation"
  ]
}